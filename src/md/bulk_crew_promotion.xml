<?xml version="1.0" encoding="UTF-8"?>
<mdscript xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" name="VAS_BulkCrewPromotion" xsi:noNamespaceSchemaLocation="md.xsd">
  <!--
    Bulk right-click actions, routed to the companion Lua via Lua events:

      [Promote best crew (selected ships)]    - on a selected/right-clicked player
                                                 ship, or on free sector space with
                                                 selected player ships. Each target
                                                 ship gets its best on-board
                                                 service/marine crew promoted to pilot.

      [Promote best crew (all player ships)]  - on the player's PHQ. Walks every
                                                 player ship and runs the in-place
                                                 promote on each.

      [Reshuffle captains (selected ships)]   - immediate selected-ships reshuffle,
                                                 preserving the original behavior.

      [Configured reshuffle (selected ships)] - opens the run-options window first,
                                                 then reshuffles selected ships.

      [Reshuffle captains (all player ships)] - opens the run-options window first,
                                                 then runs the whole-empire reshuffle.
                                                 Candidate pool is service / marine /
                                                 unassigned crew only. The Lua side
                                                 sorts by raw piloting first, skips
                                                 capped and captain-only ships, and
                                                 runs large reshuffles over onUpdate.
  -->
  <cues>
    <!-- Config STATE container. Defaults live in exactly one place: SeedDefaults
         below. The Extension Options UI is in bulk_crew_promotion_config_menu.xml
         and reads/writes this cue cross-script. -->
    <cue name="ModConfig" namespace="this" version="1">
      <actions>
        <run_actions ref="SeedDefaults"/>
      </actions>
    </cue>

    <!--@doc
        Idempotent defaults seeder. Seeds any missing ModConfig var and heals
        missing keys in the run-config tables (global + player.entity copies) -
        plain cues run their actions once per playthrough, so vars/keys added in
        a mod UPDATE never appear in old saves unless seeded here on load.
        String-coercion null checks: explicit false/0 must NOT be re-seeded. -->
    <library name="SeedDefaults" purpose="run_actions">
      <actions>
        <!-- Options-menu-only settings (not part of a reshuffle run config) -->
        <set_value name="$menuDefaults" exact="table[
          $debugEnabled = false,
          $logReasons = 'grouped',
          $allActionsOnlyOnHQ = true,
        ]"/>
        <!-- Per-run reshuffle settings; also the key set of the run-config tables -->
        <set_value name="$runDefaults" exact="table[
          $targetIncludeMilitary = true,
          $targetIncludeMiners = true,
          $targetIncludeTraders = true,
          $targetIncludeBuilders = true,
          $targetIncludeSalvage = true,
          $targetIncludeAuxiliary = true,
          $targetIncludeOther = true,
          $targetIncludeShipS = true,
          $targetIncludeShipM = true,
          $targetIncludeShipL = true,
          $targetIncludeShipXL = true,
          $donorIncludeMilitary = true,
          $donorIncludeMiners = true,
          $donorIncludeTraders = true,
          $donorIncludeBuilders = true,
          $donorIncludeSalvage = true,
          $donorIncludeAuxiliary = true,
          $donorIncludeOther = true,
          $donorIncludeShipS = true,
          $donorIncludeShipM = true,
          $donorIncludeShipL = true,
          $donorIncludeShipXL = true,
          $candidateService = true,
          $candidateMarine = true,
          $candidateUnassigned = true,
          $donorReserveCivilianService = 50,
          $donorReserveCivilianMarine = 50,
          $donorReserveMilitaryService = 80,
          $donorReserveMilitaryMarine = 80,
          $recipientMinHull = 0,
          $recipientMinShield = 0,
          $minPilotingImprovement = 1,
          $minCombinedImprovementPercent = 0,
          $sameCommanderOnly = false,
          $unassignedShipsOnly = false,
          $withoutCaptainOnly = false,
          $includeStationManagers = false,
          $preserveEliteMarines = true,
          $eliteMarineBoardingThreshold = 12,
        ]"/>

        <!-- Seed missing ModConfig vars from the defaults -->
        <do_for_each name="$key" in="$menuDefaults.keys.list">
          <do_if value="(@md.VAS_BulkCrewPromotion.ModConfig.{$key} + '') == 'null'">
            <set_value name="md.VAS_BulkCrewPromotion.ModConfig.{$key}" exact="$menuDefaults.{$key}"/>
          </do_if>
        </do_for_each>
        <do_for_each name="$key" in="$runDefaults.keys.list">
          <do_if value="(@md.VAS_BulkCrewPromotion.ModConfig.{$key} + '') == 'null'">
            <set_value name="md.VAS_BulkCrewPromotion.ModConfig.{$key}" exact="$runDefaults.{$key}"/>
          </do_if>
        </do_for_each>

        <!-- Heal the run-config tables key by key. Values come from ModConfig
             (the possibly user-edited defaults), not from $runDefaults. -->
        <do_if value="not @global.$vas_bcp_config">
          <set_value name="global.$vas_bcp_config" exact="table[]"/>
        </do_if>
        <do_if value="not @player.entity.$vas_bcp_config">
          <set_value name="player.entity.$vas_bcp_config" exact="table[]"/>
        </do_if>
        <do_for_each name="$key" in="$runDefaults.keys.list">
          <do_if value="(@global.$vas_bcp_config.{$key} + '') == 'null'">
            <set_value name="global.$vas_bcp_config.{$key}" exact="md.VAS_BulkCrewPromotion.ModConfig.{$key}"/>
          </do_if>
          <do_if value="(@player.entity.$vas_bcp_config.{$key} + '') == 'null'">
            <set_value name="player.entity.$vas_bcp_config.{$key}" exact="md.VAS_BulkCrewPromotion.ModConfig.{$key}"/>
          </do_if>
        </do_for_each>
      </actions>
    </library>

    <!-- Heal old saves on every load and re-push the Lua blackboard mirrors.
         Root's once-per-playthrough actions can't be trusted with anything
         added after release. -->
    <!-- event_universe_generated fires both at new-game start AND on every
         savegame load (md.xsd), so it alone covers all sessions - adding
         event_game_loaded would double-fire this cue on loads. -->
    <cue name="InitDefaults" instantiate="true">
      <conditions>
        <event_universe_generated/>
      </conditions>
      <actions>
        <run_actions ref="SeedDefaults"/>
        <set_value name="player.entity.$vas_bcp_debug_chance" exact="if md.VAS_BulkCrewPromotion.ModConfig.$debugEnabled then 100 else 0"/>
        <set_value name="player.entity.$vas_bcp_log_reasons" exact="md.VAS_BulkCrewPromotion.ModConfig.$logReasons"/>
      </actions>
    </cue>

    <!-- The right-click entries, the run-options window and the Lua result
         listeners live in bulk_crew_promotion_interact_menu.xml
         (VAS_BulkCrewPromotion_Interact); the old Root's mirror pushes are
         superseded by InitDefaults above, which re-runs every load. -->
  </cues>
</mdscript>
